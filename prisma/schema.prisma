// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Models
model User {
  id        String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole   @default(STUDENT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  studentProfile  StudentProfile?
  lecturerProfile LecturerProfile?
  attendanceRecords AttendanceRecord[]

  accounts Account[]
  sessions Session[]

  @@index([email])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  ext_expires_in     Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Student Profile
model StudentProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  studentId       String    @unique
  major           String?
  enrollmentYear  Int?
  totalAttendance Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseEnrollments CourseEnrollment[]
  attendanceMarks   AttendanceMark[]

  @@index([studentId])
}

// Lecturer Profile
model LecturerProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  department String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses Course[]
  attendanceSessions AttendanceSession[]
}

// Course Management
model Course {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  description  String?
  lecturerId   String
  semester     String
  year         Int
  capacity     Int
  classGroup   String?   // For different class groups (LA1, LA2, etc.)
  classType    ClassType // LECTURE, TUTORIAL, LAB, PRACTICAL
  scheduleDay  String?   // Mon, Tue, Wed, etc.
  scheduleTime String?   // 13:00-15:00
  venue        String?   // G603, B006, etc.
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lecturer         LecturerProfile @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  enrollments      CourseEnrollment[]
  attendanceSessions AttendanceSession[]
  classSessions    ClassSession[]

  @@index([lecturerId])
  @@index([code])
}

// Class Sessions - Weekly classes (like LA1, LA2, etc.)
model ClassSession {
  id          String    @id @default(cuid())
  courseId    String
  sessionType SessionType // LECTURE, TUTORIAL, LAB, PRACTICAL
  groupNumber String?    // 01, 02, etc.
  dayOfWeek   String     // Mon, Tue, Wed, Thu, Fri
  startTime   String     // 10:00
  endTime     String     // 12:00
  venue       String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  course           Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  weeklyAttendance WeeklyAttendance[]
  attendanceSessions AttendanceSession[]

  @@unique([courseId, sessionType, groupNumber])
  @@index([courseId])
}

// Weekly Attendance Records - For tracking attendance per date
model WeeklyAttendance {
  id               String   @id @default(cuid())
  classSessionId   String
  attendanceDate   DateTime // The actual date of the class (e.g., 2026-03-03)
  weekNumber       Int      // Week number in semester
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  classSession     ClassSession      @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  attendanceMarks  AttendanceMark[]

  @@unique([classSessionId, attendanceDate])
  @@index([classSessionId])
  @@index([attendanceDate])
}

// Individual Student Attendance Marks
model AttendanceMark {
  id               String   @id @default(cuid())
  studentId        String
  weeklyAttendanceId String
  status           AttendanceStatus @default(ABSENT) // PRESENT, ABSENT, LATE, EXCUSED
  remarks          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student          StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  weeklyAttendance WeeklyAttendance  @relation(fields: [weeklyAttendanceId], references: [id], onDelete: Cascade)

  @@unique([studentId, weeklyAttendanceId])
  @@index([weeklyAttendanceId])
  @@index([studentId])
}

// Course Enrollment
model CourseEnrollment {
  id        String    @id @default(cuid())
  studentId String
  courseId  String
  enrolledAt DateTime  @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId])
}

// Active Attendance Sessions (QR Code based)
model AttendanceSession {
  id              String    @id @default(cuid())
  courseId        String
  classSessionId  String?   // Link to specific class session
  lecturerId      String
  qrCode          String    @unique
  startTime       DateTime
  endTime         DateTime
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classSession    ClassSession?   @relation(fields: [classSessionId], references: [id])
  lecturer        LecturerProfile @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  attendanceRecords AttendanceRecord[]

  @@index([courseId])
  @@index([lecturerId])
}

// Real-time Attendance Records (for QR/Facial recognition)
model AttendanceRecord {
  id           String    @id @default(cuid())
  userId       String
  sessionId    String
  checkInTime  DateTime
  recognitionMethod RecognitionMethod
  status       AttendanceStatus @default(PRESENT)
  latitude     Float?
  longitude    Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@index([userId])
}

// Enums
enum UserRole {
  STUDENT
  LECTURER
}

enum ClassType {
  LECTURE
  TUTORIAL
  LAB
  PRACTICAL
}

enum SessionType {
  LECTURE
  TUTORIAL
  LAB
  PRACTICAL
}

enum RecognitionMethod {
  FACIAL
  QR_CODE
  MOBILE_CHECKIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}
