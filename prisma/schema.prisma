generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth (NextAuth required models) ──────────────────────────────

model User {
  id            String    @id @default(cuid())
  orgId         String?
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(STUDENT)
  programName   String?
  qrState       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  disabledAt    DateTime?

  unitRegistrations UnitRegistration[]
  ledSessions       ClassSession[]     @relation("LecturerSessions")
  accounts          Account[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AccountSession")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Units ─────────────────────────────────────────────────────────

model Unit {
  id   String @id @default(cuid())
  code String @unique
  name String

  unitRegistrations UnitRegistration[]
}

// ── Unit Registration ─────────────────────────────────────────────

model UnitRegistration {
  id         String     @id @default(cuid())
  unitId     String
  userId     String
  name       String?
  year       Int
  semester   String
  userStatus UserStatus

  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSessions ClassSession[]

  @@unique([unitId, userId])
  @@index([userId])
  @@index([unitId])
}

// ── Class Sessions ────────────────────────────────────────────────

model ClassSession {
  id                 String      @id @default(cuid())
  unitRegistrationId String
  lecturerId         String
  sessionName        SessionName
  sessionTime        DateTime
  sessionDuration    Int
  weekNumber         Int?
  subcomponent       String?
  groupNo            String?

  unitRegistration  UnitRegistration        @relation(fields: [unitRegistrationId], references: [id], onDelete: Cascade)
  lecturer          User                    @relation("LecturerSessions", fields: [lecturerId], references: [id])
  attendanceData    ClassAttendanceData[]
  attendanceRecords ClassAttendanceRecord[]

  @@index([unitRegistrationId])
  @@index([lecturerId])
}

// ── Attendance Data (raw QR scan payloads) ────────────────────────

model ClassAttendanceData {
  id                String   @id @default(cuid())
  classSessionId    String
  scanPayload       Json
  scanMethod        String?
  verificationStage String?
  createdAt         DateTime @default(now())

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@index([classSessionId])
}

// ── Attendance Record (verified) ──────────────────────────────────

model ClassAttendanceRecord {
  id                     String           @id @default(cuid())
  classSessionId         String
  studentId              String
  status                 AttendanceStatus @default(PENDING)
  verifiedAt             DateTime?
  verificationConfidence Float?
  createdAt              DateTime         @default(now())

  classSession ClassSession         @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  evidence     AttendanceEvidence[]

  @@unique([classSessionId, studentId])
  @@index([classSessionId])
  @@index([studentId])
}

// ── Attendance Evidence (MC / sick leave uploads) ─────────────────

model AttendanceEvidence {
  id                 String   @id @default(cuid())
  attendanceRecordId String
  uploadedBy         String
  fileUrl            String
  reason             String?
  uploadedAt         DateTime @default(now())
  status             String   @default("PENDING")

  attendanceRecord ClassAttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  @@index([attendanceRecordId])
}

// ── Enums ─────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  LECTURER
}

enum UserStatus {
  STUDENT
  LECTURER
  TUTOR
}

enum SessionName {
  LECTURE
  TUTORIAL
  LAB
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PENDING
}
