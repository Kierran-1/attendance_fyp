generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(cuid())
  orgId             String?
  email             String             @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  role              UserRole           @default(STUDENT)
  programName       String?
  nationality       String?
  schoolStatus      String?
  qrState           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  disabledAt        DateTime?
  accounts          Account[]
  sessions          Session[]
  ledSessions       ClassSession[]     @relation("LecturerSessions")
  unitRegistrations UnitRegistration[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("AccountSession")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Unit {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  unitRegistrations UnitRegistration[]
  classSessions     ClassSession[]
}

model UnitRegistration {
  id            String         @id @default(cuid())
  unitId        String
  userId        String
  name          String?
  termCode      String?
  year          Int
  semester      String
  userStatus    UserStatus
  classSessions ClassSession[]
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([unitId, userId, name])
  @@index([userId])
  @@index([unitId])
}

model ClassSession {
  id                 String                  @id @default(cuid())
  unitRegistrationId String?
  unitId             String?
  lecturerId         String
  sessionName        SessionName
  scheduledDate      DateTime?
  sessionTime        DateTime?
  sessionDuration    Int?
  subcomponent       String?
  groupNo            String?
  location           String?
  day                String?

  attendanceData     ClassAttendanceData[]
  attendanceRecords  ClassAttendanceRecord[]
  lecturer           User                    @relation("LecturerSessions", fields: [lecturerId], references: [id])
  unitRegistration   UnitRegistration?       @relation(fields: [unitRegistrationId], references: [id], onDelete: SetNull)
  unit               Unit?                   @relation(fields: [unitId], references: [id])

  @@index([unitRegistrationId])
  @@index([lecturerId])
  @@index([unitId])
}

model ClassAttendanceData {
  id                String       @id @default(cuid())
  classSessionId    String
  studentId         String?
  scanPayload       Json
  scanMethod        String?
  verificationStage String?
  challengeToken    String?
  usedAt            DateTime?    // Mark when challenge token was used to prevent reuse
  createdAt         DateTime     @default(now())
  classSession      ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId, verificationStage]) // Prevent duplicate stage records
  @@index([classSessionId])
  @@index([studentId])
}

model ClassAttendanceRecord {
  id                     String               @id @default(cuid())
  classSessionId         String
  studentId              String
  status                 AttendanceStatus     @default(PENDING)
  verifiedAt             DateTime?
  verificationConfidence Float?
  createdAt              DateTime             @default(now())
  evidence               AttendanceEvidence[]
  classSession           ClassSession         @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([classSessionId])
  @@index([studentId])
}

model AttendanceEvidence {
  id                 String                @id @default(cuid())
  attendanceRecordId String
  uploadedBy         String
  fileUrl            String
  reason             String?
  uploadedAt         DateTime              @default(now())
  status             String                @default("PENDING")
  attendanceRecord   ClassAttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  @@index([attendanceRecordId])
}

enum UserRole {
  STUDENT
  LECTURER
}

enum UserStatus {
  STUDENT
  LECTURER
  TUTOR
}

enum SessionName {
  LECTURE
  TUTORIAL
  LAB
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PENDING
}
